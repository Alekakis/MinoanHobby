import Redis from 'ioredis';

const redis = new Redis("redis://default:9j6w6SPasZTuekVEVPTnoVCXNDFrRN0k@admirable-prosperous-insurance-32661.db.redis.io:10020");

export default async function handler(req, res) {
    // Επιτρέπουμε μόνο POST αιτήματα από τη Viva Wallet
    if (req.method !== 'POST') {
        return res.status(405).json({ error: 'Method not allowed' });
    }

    let event = req.body;
    if (typeof event === 'string') {
        try { event = JSON.parse(event); } catch(e) {}
    }

    // Αν η Viva στείλει verification check στην αρχή, απαντάμε αμέσως
    if (event && event.KeyVerification) {
        return res.status(200).json({ KeyVerification: event.KeyVerification });
    }

    try {
        const eventData = event.EventData || {};
        const orderCode = eventData.OrderCode;
        const eventTypeId = event.EventTypeId;
        const statusId = eventData.StatusId;

        if (!orderCode) {
            return res.status(200).send('No order code found');
        }

        // --- ΠΕΡΙΠΤΩΣΗ 1: ΕΠΙΤΥΧΗΣ ΠΛΗΡΩΜΗ (Success) ---
        if (eventTypeId === 1796 || statusId === 'F') { 
            
            // 1. Ανάκτηση στοιχείων από το Redis (πρέπει να τα έχεις αποθηκεύσει στο create-order)
            const orderDetailsRaw = await redis.get(`viva:order:details:${orderCode}`);
            const orderDetails = orderDetailsRaw ? JSON.parse(orderDetailsRaw) : { teamName: "Άγνωστη", price: "0" };

            // 2. Σύνθεση δεδομένων για το Web3Forms
            const emailData = {
                access_key: "ef54407f-a593-41c3-8fce-209c5ebf6e97",
                subject: "💰 Νέα Επιτυχής Παραγγελία!",
                from_name: "Minoan Hobby System",
                "Order Code": orderCode,
                "Είδος/Ομάδα": orderDetails.teamName,
                "Ποσό": orderDetails.price + " €",
                "Κατάσταση": "Η πληρωμή ολοκληρώθηκε επιτυχώς!"
            };

            // 3. Αποστολή email (Server-side, αξιόπιστα)
            try {
                await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(emailData)
                });
            } catch (err) {
                console.error("Email sending failed:", err);
            }

            // 4. Οριστικοποίηση stock για ομάδες
            const teamIdMapped = await redis.get(`viva:mapping:team:${orderCode}`);
            if (teamIdMapped) {
                await redis.set(`team:status:${teamIdMapped}`, 'sold');
                await redis.del(`viva:mapping:team:${orderCode}`);
            }

            // 5. Καθαρισμός προσωρινών κλειδιών
            await redis.del(`viva:order:details:${orderCode}`);
            await redis.del(`viva:pending:ducks:${orderCode}`);

            return res.status(200).send('OK');
        }

        // --- ΠΕΡΙΠΤΩΣΗ 2: ΑΠΟΤΥΧΙΑ / ΑΚΥΡΩΣΗ ΠΛΗΡΩΜΗΣ ---
        if (statusId === 'E' || statusId === 'X' || statusId === 'C') {
            
            // Επιστροφή stock αν απέτυχε
            const pendingDucksQty = await redis.get(`viva:pending:ducks:${orderCode}`);
            if (pendingDucksQty) {
                await redis.incrby('product:stock:ducks', parseInt(pendingDucksQty));
                await redis.del(`viva:pending:ducks:${orderCode}`);
            }

            const teamIdMapped = await redis.get(`viva:mapping:team:${orderCode}`);
            if (teamIdMapped && teamIdMapped !== 'ducks') {
                await redis.del(`team:status:${teamIdMapped}`);
                await redis.del(`viva:mapping:team:${orderCode}`);
            }

            // Καθαρισμός details παραγγελίας αν ακυρώθηκε
            await redis.del(`viva:order:details:${orderCode}`);

            return res.status(200).send('Stock Released due to failure');
        }

        return res.status(200).send('Event processed');

    } catch (error) {
        console.error("Webhook Error:", error);
        return res.status(500).json({ error: error.message });
    }
}
